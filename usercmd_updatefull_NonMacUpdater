brew_outdated_formulas=$(brew outdated --formula --greedy 2>&1                                                                    | awk '{print $1}')
brew_outdated_casks=$(brew outdated  --cask --greedy 2>&1                                                                         | awk '{print $1}')

# 将需要更新的包分别存储
packages_brew=($brew_outdated)
packages_brew_formulas=()
for pkg in ${brew_outdated_formulas}; do
    [[ -n "$pkg" ]] && packages_brew_formulas+=("$pkg")
done
packages_brew_casks=()
for pkg in ${brew_outdated_casks}; do
    [[ -n "$pkg" ]] && packages_brew_casks+=("$pkg")
done

echo -e ""                                                                            | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"

# 如果有需要更新的 Homebrew 软件包，则执行下载
if [ ${#packages_brew[@]} -ne 0 ]; then
  # 第 2 步：并行下载（提高下载速度）
  printf "\033[1;34m[Download]\033[0m "
  printf "[Download] "                                                                | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" > /dev/null
  echo -e "开始下载：HomeBrew formula / cask（并行）..."                              | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
  
  # 筛选需要下载的 formula 软件包：如果缓存中已有完整的新版本则跳过
  packages_to_fetch_formulas=()
  for pkg in "${packages_brew_formulas[@]}"; do
      [[ -z "$pkg" ]] && continue  # 跳过空名称项（以防万一）
      cache_path=$(brew --cache --formula "$pkg")
      if [ -f "$cache_path" ]; then
          local_sha=$(shasum -a 256 "$cache_path" | awk '{print $1}')
          expected_sha=$(brew info --json=v2 "$pkg" | grep -o '"sha256":"[0-9a-f]\{64\}"' | head -n 1 | cut -d '"' -f 4)
          if [ -n "$expected_sha" ] && [ "$local_sha" = "$expected_sha" ]; then
              echo "🔰 [跳过] 已缓存 最新版本 [formula] ：$pkg "                      | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
              continue  # 略过重新下载
          fi
      fi
      packages_to_fetch_formulas+=("$pkg")
  done
  
  # 筛选需要下载的 cask 软件包：如果缓存中已有完整的新版本则跳过
  packages_to_fetch_casks=()
  for pkg in "${packages_brew_casks[@]}"; do
      [[ -z "$pkg" ]] && continue  # 跳过空名称项
      cache_path=$(brew --cache --cask "$pkg")
      if [ -f "$cache_path" ]; then
          local_sha=$(shasum -a 256 "$cache_path" | awk '{print $1}')
          expected_sha=$(brew info --cask --json=v2 "$pkg" 2>/dev/null | grep -o '"sha256":"[0-9a-f]\{64\}"' | head -n 1 | cut -d '"' -f 4)
          # 某些 cask 没有 SHA 信息（:latest 或 auto_updates），则不强制校验
          if [[ "$expected_sha" == "null" || -z "$expected_sha" ]]; then
              echo "🔰 [跳过] 已缓存 无校验版 [cask] ：$pkg "                           | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
              continue 
          fi 
          if [[ "$local_sha" == "$expected_sha" ]]; then 
              echo "🔰 [跳过] 已缓存 最新版本 [cask]  ：$pkg "                          | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
              continue
          fi
      fi
      packages_to_fetch_casks+=("$pkg")
  done
  
  # 并行下载需要更新的 formula 和 cask（使用 --retry 自动校验缓存有效性） 注意，与 下面的 parallel 方案 二选一。建议使用Parallel，因为速度更快。
  # printf '%s\n' "${packages_to_fetch_formulas[@]}" | xargs -n1 -P16 brew fetch --formula --retry         | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
  # printf '%s\n' "${packages_to_fetch_casks[@]}"    | xargs -n1 -P8 brew fetch --cask --retry             | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"

  # 确保 GNU Parallel 已安装（macOS 可通过 Homebrew 安装）
  if ! command -v parallel &>/dev/null; then
      brew install parallel   # 安装 GNU Parallel 并行执行工具 [oai_citation:3‡formulae.brew.sh](https://formulae.brew.sh/formula/parallel#:~:text=Install%20command%3A)
  fi
  
  # 并行下载 formula （最多16个并发），每个任务完成后输出状态 （使用 --retry 自动校验缓存有效性）
  if [ ${#packages_to_fetch_formulas[@]} -gt 0 ]; then
    parallel --will-cite --line-buffer --unsafe -j16 \
        "if brew fetch --formula --retry {} 2>&1 | tee -a '$LOG_FULL_LAST' '$LOG_FULL_FILE'; then echo -e '✅  下载成功 [formula] ：{} '| tee -a '$LOG_FULL_LAST' '$LOG_FULL_FILE' ; else echo -e '❌  下载失败 [formula] ：{} ' | tee -a '$LOG_FULL_LAST' '$LOG_FULL_FILE' ; fi" \
        ::: "${packages_to_fetch_formulas[@]}" &
  fi

  # 并行下载 cask    （最多16个并发），每个任务完成后输出状态 （使用 --retry 自动校验缓存有效性）
  if [ ${#packages_to_fetch_casks[@]} -gt 0 ]; then
    parallel --will-cite --line-buffer --unsafe -j16 \
        "if brew fetch --cask --retry {} 2>&1 | tee -a '$LOG_FULL_LAST' '$LOG_FULL_FILE'; then echo -e '✅  下载成功 [cask] ：{} ' | tee -a '$LOG_FULL_LAST' '$LOG_FULL_FILE' ; else echo -e '❌  下载失败 [cask] ：{} ' | tee -a '$LOG_FULL_LAST' '$LOG_FULL_FILE'; fi" \
        ::: "${packages_to_fetch_casks[@]}" &
  fi
  
  wait  # 等待所有并行任务完成
 #echo -e "✅ 所有下载任务 已完成/已退出"                                               | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" 

  # exit 0        # 用于调试 ！！

  # 第 3 步：串行安装（Homebrew formula）
  if [ ${#packages_brew_formulas[@]} -ne 0 ] ; then
      echo -e ""                                                                        | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
      printf "\033[1;34m[Install]\033[0m "
      printf "[Install] "                                                               | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" > /dev/null
      echo -e "开始更新：HomeBrew formula（串行）..."                                   | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"

      # 循环逐个处理每个过期的 Homebrew formula
      for formula in "${packages_brew_formulas[@]}"; do
          # ---------- 尝试升级 ----------
          brew upgrade --force "$formula" 2>&1                                          | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
          upgrade_exit=${PIPESTATUS[0]}        # 取 brew upgrade 的退出码
          final_exit=$upgrade_exit             # 先假定最终状态 = 升级状态

          # ---------- 若升级失败则尝试重装 ----------
          if [ $upgrade_exit -ne 0 ] ; then
              echo -e "upgrade 失败，尝试 reinstall：$formula ..."                      | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
              brew reinstall "$formula" 2>&1                                            | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
              reinstall_exit=${PIPESTATUS[0]}  # 取 brew reinstall 的退出码
              final_exit=$reinstall_exit
          fi

          # ---------- 根据最终状态输出结果 ----------
          if [ $final_exit -eq 0 ] ; then
              echo -e "✅  更新成功 [formula] ：$formula"                               | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
              echo -e "--------------------"                                            | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
          else  
              echo -e "❌  更新失败 [formula] ：$formula"                               | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
              echo -e "--------------------"                                            | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
          fi
      done
  else
      echo -e ""                                                                        | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
      printf "\033[1;34m[Install]\033[0m "
      printf "[Install] "                                                               | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" > /dev/null
      echo -e "无需更新：HomeBrew formula ..."                                          | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
      echo -e ""                                                                        | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
  fi

  # 第 4 步：串行安装（Homebrew cask）
  if [ ${#packages_brew_casks[@]} -ne 0 ] ; then
    printf  "\033[1;34m[Install]\033[0m "
    printf  "[Install] "                                                                | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" > /dev/null
    echo -e "开始更新：HomeBrew cask（串行 ）..."                                       | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
    # 逐个安装 每个待更新的 cask app
    for cask in $brew_outdated_casks; do
        # 利用 brew info 提取 Cask 安装的 .app 应用包名称
        app_line=$(brew info --cask "$cask" | grep -m1 '\.app (App)')
        # 上述命令从 brew info 输出中找出包含“.app (App)”的行，并去掉后面的标记，取得应用程序包名
        app_name=$(echo "$app_line" | sed -e 's/\.app (App)//' -e 's/^[[:space:]]*//')
        # **初始化 was_running 标志**
        was_running=false
        # 确认提取到的应用名不为空
        if [[ -n "$app_name" ]]; then
            # 如果该应用正在运行，先尝试退出
            if pgrep -ix "$app_name" > /dev/null; then
                echo -e "检测到 $app_name 正在运行，尝试退出应用..."                                          | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
               # 组合命令，用 () 分组，再把 stderr 合并到 stdout 后送给 tee 
                ( osascript -e "tell application \"$app_name\" to quit" || killall "$app_name" ) 2>&1         | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
                sleep 5  # 等待数秒让应用完全退出   
                was_running=true    
            fi  
        else    
            echo "⚠️ 警告：无法从 brew info 提取 $cask 的应用名称，无法自动关闭应用，将直接升级。"              | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
        fi  

        # 升级 cask 应用    
        brew upgrade --cask --greedy "$cask" 2>&1                                       | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
        upgrade_exit=${PIPESTATUS[0]}           # 获取 brew upgrade 的退出码    
        final_exit=$upgrade_exit               # 先假定最终状态为 upgrade 的状态    

        if [ $upgrade_exit -ne 0 ]; then    
            echo -e "⚠️ upgrade 升级失败，$cask，尝试使用 reinstall 重新安装..."        | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
            brew reinstall --cask --force "$cask" 2>&1                                  | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
            reinstall_exit=${PIPESTATUS[0]}    # 获取 brew reinstall 的退出码   
            #  -------- 以下代码 未验证  如遇问题请关闭 -------- #
            if [ $reinstall_exit -ne 0 ]; then
                # 若重装失败且检测到应用仍在运行，强制关闭后再重试一次
                if pgrep -ix "$app_name" > /dev/null; then
                    echo -e "⚠️ 检测到 $app_name 仍在运行，强制关闭后再次尝试安装..."   | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
                    pid=$(pgrep -f "$app_name")
                    if [ -n "$pid" ]; then
                        kill -9 "$pid"
                    fi
                    brew reinstall --cask --force "$cask" 2>&1                          | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
                    reinstall_exit=${PIPESTATUS[0]}
                fi
            fi
            #  -------- 以上代码 未验证  如遇问题请关闭 -------- #
            final_exit=$reinstall_exit       # 将最终状态更新为 reinstall 的状态  
        fi  

        # 如果之前关闭了应用，更新完成后重新打开 
        if [[ "$was_running" = true && -n "$app_name" ]]; then  
            echo "重新启动此前关闭的应用：$app_name ..."                                | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
            open -a "$app_name" 2>&1                                                    | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
        fi

        # 根据最终状态输出结果（成功或失败），然后继续处理下一个 cask
        if [ $final_exit -eq 0 ]; then
            echo "✅  更新成功 [cask] : $cask."                                         | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
        else    
            echo "❌  更新失败 [cask] : $cask."                                         | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
        fi
        echo -e "--------------------"                                                  | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
    done
    echo -e ""                                                                          | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
  else  
    printf  "\033[1;34m[Install]\033[0m "   
    printf  "[Install] "                                                                | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"  > /dev/null
    echo -e "无需更新：HomeBrew cask ..."                                               | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
    echo -e ""                                                                          | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
  fi    

 #brew upgrade --greedy --debug --force                                                 | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE""  ###### 仅作为Debug使用！！！

else    
  printf  "\033[1;34m[Download & Install]\033[0m "    
  printf  "[Download & Install] "                                                       | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" > /dev/null
  echo -e "当前没有需要更新的 Homebrew 包 !!! "                                         | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
  echo -e ""                                                                            | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" 
fi


# 第 5 步： 清洁
printf  "\033[1;34m[Clean]\033[0m "
printf  "[Clean] "                                                                      | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" > /dev/null

# 获取过时应用程序的ID
app_ids=$(echo -e "$outdated_mas_apps" | awk '{print $1}'  | grep -E '^[0-9]+$')
# 获取已安装应用程序的列表
installed_apps=$( mas list )
# 存储需要关闭和重启的应用程序
apps_to_restart=()

# 检查并关闭正在运行的应用程序
for id in $app_ids; do
  # 从已安装应用列表中提取应用名称，去掉ID和可能的版本号
  app_name=$(echo -e "$installed_apps" | grep "^$id" | awk '{$1=""; print substr($0,2)}' | sed 's/ ([0-9].*)$//')
  if [ -n "$app_name" ]; then
    # 使用 osascript 检查应用是否正在运行
    if osascript -e "tell application \"System Events\" to (name of processes) contains \"$app_name\"" | grep -q "true"; then
      echo -e "检测到 $app_name 正在运行，正在尝试关闭..."                            | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" 
      # 安全关闭应用程序
      osascript -e "tell application \"$app_name\" to quit"
      # 等待应用完全关闭（最多10秒）
      for i in {1..10}; do
        if ! osascript -e "tell application \"System Events\" to (name of processes) contains \"$app_name\"" | grep -q "true"; then
          break
        fi
        sleep 1
      done
      # 如果应用仍未关闭，尝试强制关闭
      if osascript -e "tell application \"System Events\" to (name of processes) contains \"$app_name\"" | grep -q "true"; then
        echo -e "无法正常关闭 $app_name，正在尝试强制关闭..."                         | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" 
        # 获取应用程序的PID
        pid=$(pgrep -f "$app_name")
        if [ -n "$pid" ]; then
          kill -9 $pid
          echo -e "已强制关闭 $app_name (PID: $pid)"                                  | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" 
        else
          echo -e "无法获取 $app_name 的PID，跳过强制关闭"                            | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE" 
        fi
      fi
      # 再次检查应用是否已关闭成功
      if osascript -e "tell application \"System Events\" to (name of processes) contains \"$app_name\"" | grep -q "true"; then
        echo -e "✘  $app_name 无法关闭，跳过重启该应用。"                              | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
      else
        # 已成功关闭的应用加入重启列表
        apps_to_restart+=("$app_name")
        echo -e "✓  $app_name 已关闭，稍后将重新启动。"                                | tee -a "$LOG_FULL_LAST" "$LOG_FULL_FILE"
      fi
    fi
  fi
done

